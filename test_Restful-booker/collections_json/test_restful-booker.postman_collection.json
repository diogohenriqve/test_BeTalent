    {
      "name": "LoginCorreto",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "// 1. Valida se logou com sucesso",
              "pm.test(\"Status code é 200 OK\", function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "// 2. Valida se retornou token",
              "pm.test(\"Response contém token\", function () {",
              "    const res = pm.response.json();",
              "    pm.expect(res).to.have.property('token');",
              "    pm.expect(res.token).to.be.a('string');",
              "});",
              "",
              "// 3. Salva o token automaticamente pra usar depois",
              "const jsonData = pm.response.json();",
              "pm.environment.set(\"auth_token\", jsonData.token);",
              ""
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        },
